# Keycloak + Traefik + Let's Encrypt — Environment Variables
# Copy this file to `.env` and fill in each value before `docker compose up`.
# `.env` is gitignored — never commit real credential values.
#
# ──────────────────────────────────────────────────────────────────────────────
# Traefik reverse proxy
# ──────────────────────────────────────────────────────────────────────────────

# Traefik image tag. Pin to a specific minor for reproducibility; Dependabot
# bumps the digest weekly (see `docker` ecosystem in .github/dependabot.yml).
TRAEFIK_IMAGE_TAG=traefik:3.2

# Log level: DEBUG, INFO, WARN, ERROR. Use WARN or ERROR in production.
TRAEFIK_LOG_LEVEL=WARN

# Email address for Let's Encrypt renewal notices. REQUIRED.
TRAEFIK_ACME_EMAIL=admin@example.com

# Hostname for the Traefik dashboard (basic-auth protected).
TRAEFIK_HOSTNAME=traefik.keycloak.example.com

# ──────────────────────────────────────────────────────────────────────────────
# Traefik dashboard Basic Authentication
# ──────────────────────────────────────────────────────────────────────────────
# Format: USERNAME:BCRYPT_HASH  (with $ characters doubled to $$ for docker-compose)
#
# Generate a new BCrypt hash (replace YOUR_STRONG_PASSWORD):
#     htpasswd -nbB traefikadmin YOUR_STRONG_PASSWORD | sed 's/\$/\$\$/g'
#
# Or using docker without installing apache2-utils:
#     docker run --rm httpd:2.4 htpasswd -nbB traefikadmin YOUR_STRONG_PASSWORD | sed 's/\$/\$\$/g'
#
# REQUIRED — do not ship production without changing this.
TRAEFIK_BASIC_AUTH=change_me_generate_with_htpasswd_and_replace_this_string

# ──────────────────────────────────────────────────────────────────────────────
# Keycloak
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL image for Keycloak's backing database. Pin as above.
KEYCLOAK_POSTGRES_IMAGE_TAG=postgres:16

# Keycloak server image. Quay.io upstream; monitor quay.io/keycloak/keycloak
# for new releases.
KEYCLOAK_IMAGE_TAG=quay.io/keycloak/keycloak:26.2.5

# Database name, user, and password (PostgreSQL). User and db-name can stay
# default; password MUST be rotated.
KEYCLOAK_DB_NAME=keycloakdb
KEYCLOAK_DB_USER=keycloakdbuser

# REQUIRED — generate with:
#     openssl rand -base64 24 | tr -d '/+=' | head -c 32
KEYCLOAK_DB_PASSWORD=change_me_before_first_start

# Keycloak bootstrap admin account. Used only until you create real admin
# accounts via the Keycloak UI; then delete or disable this one.
KEYCLOAK_ADMIN_USERNAME=keycloakadmin

# REQUIRED — generate with:
#     openssl rand -base64 24 | tr -d '/+=' | head -c 32
KEYCLOAK_ADMIN_PASSWORD=change_me_before_first_start

# Public hostname for Keycloak. Must resolve to this server's public IP for
# Let's Encrypt TLS-ALPN challenge to succeed.
KEYCLOAK_HOSTNAME=keycloak.example.com

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL backup schedule
# ──────────────────────────────────────────────────────────────────────────────

# Time to wait after container start before running the first backup
# (Keycloak/Postgres need a moment to be fully ready).
KEYCLOAK_BACKUP_INIT_SLEEP=30m

# Interval between successive backups.
KEYCLOAK_BACKUP_INTERVAL=24h

# Backups older than this (days) are pruned by the backups container.
KEYCLOAK_POSTGRES_BACKUP_PRUNE_DAYS=7

# In-container path where backups are written. Mapped to a named volume in
# the compose file; safe to leave at default.
KEYCLOAK_POSTGRES_BACKUPS_PATH=/srv/keycloak-postgres/backups

# Filename prefix for backup archives; timestamp is appended automatically.
KEYCLOAK_POSTGRES_BACKUP_NAME=keycloak-postgres-backup
